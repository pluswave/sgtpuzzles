    <!-- These are for the game chooser (detail mode) -->
    <string name="desc_blackbox">通过发射激光并观察它们如何偏转或吸收来定位盒子内的球。</string>
    <string name="desc_bridges">用给定的桥数连接岛屿，使桥不交叉。</string>
    <string name="desc_cube">滚动立方体以收集所有颜料。</string>
    <string name="desc_dominosa">配对数字以形成完整且不同的一套多米诺骨牌。</string>
    <string name="desc_fifteen">滑动方块以形成按数字顺序排列的网格。</string>
    <string name="desc_filling">给方块编号，形成具有相同数字的区域，该数字也是区域的大小。</string>
    <string name="desc_flip">翻转方块，直到所有方块都是亮面朝上，但翻转一个方块也会翻转其相邻方块。</string>
    <string name="desc_flood">尝试通过在不同颜色中反复淹没填充左上角，使整个网格在给定步数内变为相同颜色。</string>
    <string name="desc_galaxies">将网格划分为 180 度旋转对称的区域，每个区域以点为中心。</string>
    <string name="desc_guess">猜测隐藏的颜色序列：黑色表示正确，白色表示颜色正确但位置错误。</string>
    <string name="desc_inertia">移动球以收集所有宝石而不触雷。</string>
    <string name="desc_keen">输入数字，使每行和每列恰好包含每个数字各一个，并满足算术线索。</string>
    <string name="desc_lightup">放置灯，使所有方块都被照亮，没有灯照亮另一个灯，编号的方块具有给定数量的相邻灯。</string>
    <string name="desc_loopy">绘制一条不间断且不交叉的线，使编号的方块具有给定数量的填充边。</string>
    <string name="desc_magnets">放置磁铁和空白，以满足 +/- 计数并避免磁铁排斥。</string>
    <string name="desc_map">复制 4 种颜色来给地图着色，使没有相同颜色的区域接触。</string>
    <string name="desc_mines">使用给定的相邻地雷数揭开除地雷之外的所有方块。注意：游戏在第一步移动后生成；您可能会看到"无响应"警告。</string>
    <string name="desc_mosaic">将方块着色为黑色或白色。线索给出（包括）线索方块本身的 3x3 区域中黑色方块的数量。</string>
    <string name="desc_net">旋转方块以连接所有方块（不仅仅是端点）到中心方块。</string>
    <string name="desc_netslide">滑动行和列以连接所有方块（不仅仅是端点）到中心方块。</string>
    <string name="desc_palisade">沿网格边缘绘制线条，使网格划分为相连的区域，所有区域的大小如状态行所示。此外，包含数字的每个方块应具有该数量的绘制边。</string>
    <string name="desc_pattern">填充网格，使数字按顺序表示每个黑色方块延伸的长度。</string>
    <string name="desc_pearl">绘制一条单一循环，转角在黑色方块上，白色方块前后，而非相反。</string>
    <string name="desc_pegs">通过跳过其他钉子来移除钉子，直到只剩下一个。</string>
    <string name="desc_range">放置黑色方块以限制从每个编号单元的可见距离。</string>
    <string name="desc_rect">将网格划分为矩形，每个矩形只包含一个数字，该数字也是矩形的面积。</string>
    <string name="desc_samegame">移除（2 个或更多）相同颜色的组以清除网格，较大的组得分更高。</string>
    <string name="desc_signpost">将方块连接成沿箭头的路径。</string>
    <string name="desc_singles">删除数字，使任何行/列中不出现两次数字，没有两个黑色方块相邻，且所有白色方块都连接。</string>
    <string name="desc_sixteen">滑动行和列以形成按数字顺序排列的网格。</string>
    <string name="desc_slant">在每个方块中绘制对角线，使圆圈具有给定数量的相交线，并且没有循环。</string>
    <string name="desc_solo">填充网格，使每个块、行和列恰好包含每个数字各一个。</string>
    <string name="desc_tents">放置帐篷，使每棵树都有一个单独的相邻帐篷（非对角线），没有帐篷彼此相邻（甚至对角线），并且行和列计数正确。</string>
    <string name="desc_towers">放置塔，使每行/列包含每种高度各一个，每个线索与从该点向网格内看的可见塔数相匹配。</string>
    <string name="desc_tracks">完成从 A 到 B 的轨道，使行和列包含指示的轨道段数量。轨道不能交叉。</string>
    <string name="desc_twiddle">旋转 4 个组以形成按数字顺序排列的网格。</string>
    <string name="desc_undead">用怪物填充网格，使从每个点可以看到正确数量的怪物，并考虑镜子。</string>
    <string name="desc_unequal">输入数字，使每行和每列恰好包含每个数字各一个，并满足大于号。</string>
    <string name="desc_unruly">将每个方块着色为黑色或白色，使水平或垂直方向没有三个连续的方块颜色相同，并且每行和每列包含相同数量的黑色和白色方块。</string>
    <string name="desc_untangle">移动点，直到没有线交叉。</string>
